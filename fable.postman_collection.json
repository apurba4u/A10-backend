{
  "info": {
    "name": "Fable API",
    "description": "Complete API collection for the Fable ebook sharing platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"user\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@fable.com\",\n  \"password\": \"Admin@123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get Session",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/session"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/users/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Ebooks",
      "item": [
        {
          "name": "List Ebooks (Public)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/ebooks?page=1&limit=12&sort=newest",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "ebooks"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "12" },
                { "key": "sort", "value": "newest" }
              ]
            }
          }
        },
        {
          "name": "Search Ebooks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/ebooks?search=fiction&genre=Fiction",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "ebooks"],
              "query": [
                { "key": "search", "value": "fiction" },
                { "key": "genre", "value": "Fiction" }
              ]
            }
          }
        },
        {
          "name": "Get Featured Ebooks",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/ebooks/featured"
          }
        },
        {
          "name": "Get Top Writers",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/ebooks/top-writers"
          }
        },
        {
          "name": "Get Ebook by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/ebooks/{{ebookId}}"
          }
        },
        {
          "name": "Create Ebook (Writer)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/ebooks",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My New Book\",\n  \"description\": \"A great book about something.\",\n  \"fullContent\": \"Full content here...\",\n  \"genre\": \"Fiction\",\n  \"price\": 9.99\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Update Ebook",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/ebooks/{{ebookId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Title\",\n  \"price\": 12.99\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Ebook",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/ebooks/{{ebookId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Toggle Publish",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/v1/ebooks/{{ebookId}}/publish",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Bookmarks",
      "item": [
        {
          "name": "List Bookmarks",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/bookmarks",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Add Bookmark",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/bookmarks",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ebookId\": \"{{ebookId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Remove Bookmark",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/bookmarks/{{ebookId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Wishlist",
      "item": [
        {
          "name": "List Wishlist",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/wishlist",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Add to Wishlist",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/wishlist",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ebookId\": \"{{ebookId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Remove from Wishlist",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/wishlist/{{ebookId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "User Purchase History",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/transactions/user",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Writer Sales History",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/transactions/writer",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Stripe",
      "item": [
        {
          "name": "Create Checkout (Purchase)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/stripe/create-checkout",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ebookId\": \"{{ebookId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Create Checkout (Verification)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/stripe/create-checkout",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"verification\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Check Purchase Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/stripe/check/{{ebookId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/admin/users",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update User Role",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/admin/users/{{userId}}/role",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"writer\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/admin/users/{{userId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "List All Ebooks (Admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/admin/ebooks",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Delete Ebook (Admin)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/admin/ebooks/{{ebookId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Toggle Publish (Admin)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/v1/admin/ebooks/{{ebookId}}/publish",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "List All Transactions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/admin/transactions",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Analytics Overview",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/admin/analytics/overview",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Monthly Revenue",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/admin/analytics/revenue",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/health"
          }
        }
      ]
    }
  ]
}
